#!/bin/sh
# source everything in a folder
# Save IFS so callers (e.g. sddm's wayland-session "exec $@") still
# word-split correctly after sourcein returns.
_sourcein_old_ifs="${IFS-__unset__}"
IFS='
'
set -af
# Can ignore because globbing is disabled with the `f` flag
# shellcheck disable=SC2044 disable=SC2086
for f in $(find ${1-$DIR} -mindepth 1 -maxdepth 1 -regex "${2-$REGEX}" | sort)
do
	[ ! "$QUIET" ] && echo "Sourcing $f"
	# shellcheck disable=SC1090
	[ -e "$f" ] && . "$f"
	ret="$?"
	[ "$ret" != 0 ] && echo "Return value of $f is $ret"
done
set +af
if [ "$_sourcein_old_ifs" = "__unset__" ]; then
	unset IFS
else
	IFS="$_sourcein_old_ifs"
fi
unset _sourcein_old_ifs
