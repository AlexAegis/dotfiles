{
	"[html]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
	},
	"[javascript]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
	},
	"[json]": {
		"editor.defaultFormatter": "vscode.json-language-features",
	},
	"[jsonc]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
	},
	"[markdown]": {
		"editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
	},
	"[python]": {
		"editor.defaultFormatter": "ms-python.python",
	},
	"[rust]": {
		"editor.defaultFormatter": "rust-lang.rust-analyzer",
	},
	"[svelte]": {
		"editor.defaultFormatter": "svelte.svelte-vscode",
	},
	"[typescript]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
	},
	"debug.console.fontFamily": "InconsolataGo Nerd Font Mono, Cascadia Mono, Consolas, 'Courier New', monospace",
	"debug.onTaskErrors": "showErrors",
	"editor.accessibilitySupport": "off",
	"editor.autoIndent": "full",
	"editor.codeActionsOnSave": {
		"source.fixAll": "explicit",
		"source.fixAll.eslint": "explicit",
		"source.fixAll.stylelint": "explicit",
		"source.organizeImports": "explicit",
	},
	"editor.codeLensFontFamily": "Iosevka Nerd Font, PragmataPro",
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"editor.fontFamily": "Iosevka Nerd Font, PragmataPro, InconsolataGo Nerd Font Mono, FuraCode Nerd Font, Cascadia Mono, Consolas, 'Courier New', monospace",
	"editor.fontLigatures": true,
	"editor.formatOnSave": true,
	"editor.mouseWheelZoom": true,
	"editor.quickSuggestions": {
		"comments": false,
		"other": true,
		"strings": false,
	},
	"editor.quickSuggestionsDelay": 0,
	"editor.renderControlCharacters": true,
	"editor.rulers": [
		{
			"color": "#bdbdbd11",
			"column": 80,
		},
		{
			"color": "#6d6d6d75",
			"column": 100,
		},
	],
	// Linux only
	"editor.selectionClipboard": false,
	"editor.smoothScrolling": true,
	"editor.stickyScroll.enabled": true,
	"editor.stickyTabStops": true,
	"editor.suggest.preview": true,
	"editor.suggestSelection": "first",
	"editor.tabCompletion": "off",
	"editor.tabSize": 4,
	"editor.snippetSuggestions": "bottom",
	"editor.suggest.localityBonus": true,
	"editor.useTabStops": true,
	"explorer.autoRevealExclude": {
		"**/node_modules": true,
	},
	"explorer.compactFolders": false,
	"explorer.confirmDelete": false,
	"explorer.confirmDragAndDrop": false,
	"explorer.fileNesting.enabled": true,
	"explorer.fileNesting.patterns": {
		"*.js": "${capture}*",
		"*.json": "${capture}*",
		"*.jsx": "${capture}*",
		"*.ts": "${capture}*",
		"*.tsx": "${capture}*",
		".eslintrc.cjs": ".eslintignore",
		".gitignore": ".gitattributes",
		".prettierrc.cjs": ".prettierignore",
	},
	"files.associations": {
		"vimrc": "viml",
		".dependencies": "plaintext",
	},
	"git.autofetch": true,
	"git.autorefresh": true,
	"git.confirmSync": false,
	"git.enableSmartCommit": true,
	"git.replaceTagsWhenPull": true,
	"git.openRepositoryInParentFolders": "never",
	"githubPullRequests.createOnPublishBranch": "never",
	"javascript.updateImportsOnFileMove.enabled": "always",
	"liveServer.settings.donotShowInfoMsg": true,
	"markdown.preview.typographer": true,
	"material-icon-theme.files.associations": {
		"*.animation.ts": "purescript",
		"*.facade.ts": "angular-service",
		".mocharc": "mocha",
		"project.json": "angular",
		"svelte.config.mjs": "svelte",
		"svelte.config.ts": "svelte",
		"*.prettierignore": "prettier",
	},
	"material-icon-theme.folders.associations": {
		".benchmark": "benchmark",
		".templates": "template",
		"action": "ngrx-actions",
		"actions": "ngrx-actions",
		"animation": "delta",
		"benches": "benchmark",
		"component": "components",
		"directive": "ngrx-actions",
		"directives": "ngrx-actions",
		"doc": "markdown",
		"e2e": "test",
		"effect": "Ngrx-effects",
		"effects": "Ngrx-effects",
		"guard": "ngrx-effects",
		"interceptor": "middleware",
		"module": "font",
		"modules": "font",
		"reducer": "ngrx-reducer",
		"reducers": "ngrx-reducer",
		"crates": "packages",
		"rust": "delta",
		"scope": "delta",
		"store": "Redux-store",
		"target": "dist",
		"validator": "coverage",
	},
	"python.languageServer": "Pylance",
	"remote.extensionKind": {
		"ms-azuretools.vscode-docker": "workspace",
	},
	"remote.SSH.enableDynamicForwarding": false,
	"remote.SSH.remotePlatform": {
		"esero1569": "linux",
		"pi": "linux",
	},
	"remote.SSH.showLoginTerminal": true,
	"rust-analyzer.debug.engine": "vadimcn.vscode-lldb",
	"security.workspace.trust.untrustedFiles": "open",
	"shellcheck.disableVersionCheck": true,
	"svelte.enable-ts-plugin": true,
	"telemetry.telemetryLevel": "off",
	"terminal.integrated.defaultProfile.linux": "zsh",
	"terminal.integrated.defaultProfile.windows": "PowerShell",
	"terminal.integrated.enableMultiLinePasteWarning": "auto",
	"terminal.integrated.fontFamily": "IosevkaTerm Nerd Font, PragmataPro for Powerline, InconsolataGo Nerd Font Mono, FuraCode Nerd Font, Cascadia Mono, Consolas, 'Courier New', monospace",
	"terminal.integrated.profiles.linux": {
		"bash": {
			"color": "terminal.ansiYellow",
			"icon": "terminal-bash",
			"path": "bash",
		},
		"fish": {
			"path": "fish",
		},
		"pwsh": {
			"icon": "terminal-powershell",
			"path": "pwsh",
		},
		"tmux": {
			"icon": "terminal-tmux",
			"path": "tmux",
		},
		"zsh": {
			"color": "terminal.ansiCyan",
			"icon": "terminal",
			"path": "zsh",
		},
	},
	"terminal.integrated.shellIntegration.enabled": true,
	"terminal.integrated.smoothScrolling": true,
	"terminal.integrated.tabs.enabled": false,
	"terminal.integrated.tabs.focusMode": "singleClick",
	"terminal.integrated.tabs.location": "left",
	"terminal.integrated.tabs.showActiveTerminal": "singleTerminalOrNarrow",
	"terminal.integrated.stickyScroll.enabled": true,
	"typescript.preferences.importModuleSpecifier": "relative",
	"typescript.updateImportsOnFileMove.enabled": "always",
	"window.dialogStyle": "custom",
	"workbench.editor.decorations.badges": true,
	"workbench.editor.wrapTabs": true,
	"workbench.editorAssociations": {
		"*.ipynb": "jupyter-notebook",
	},
	"workbench.iconTheme": "material-icon-theme",
	"workbench.list.smoothScrolling": true,
	"workbench.startupEditor": "none",
	"extensions.ignoreRecommendations": true,
	"debug.toolBarLocation": "commandCenter",
	"[toml]": {
		"editor.defaultFormatter": "tamasfe.even-better-toml",
	},
	"powermode.enabled": false,
	"workbench.activityBar.location": "top",
	"rust-analyzer.testExplorer": true,
	"scm.workingSets.enabled": true,
	"terminal.integrated.fontSize": 16,
	"[wgsl]": {
		"editor.defaultFormatter": "wgsl-analyzer.wgsl-analyzer",
	},
	"github.copilot.enable": {
		"*": false,
		"plaintext": false,
		"markdown": false,
		"scminput": false,
		"rust": false,
	},
	"window.customTitleBarVisibility": "auto",
	"workbench.colorTheme": "Dark+ Tweaked",
	"workbench.editor.editorActionsLocation": "titleBar",
	"screencastMode.fontSize": 46,
	"debug.console.fontSize": 10,
	"scm.inputFontSize": 11,
	"editor.overtypeOnPaste": false,
	"chat.editing.confirmEditRequestRemoval": false,
	"chat.tools.terminal.autoApprove": {
		"cargo build": true,
		"cargo check": true,
		"cargo tree": true,
		"rustc": true,
		"sed": true,
		"cargo test": true,
		"cargo fmt": true,
		"rg": true,
		"cargo run": true,
		"bun": true,
		"cargo make": true,
		"cargo llvm-cov": true,
		"cargo nextest": true,
		"uniq": true,
		"cargo info": true,
		"cargo update": true,
		"rustfmt": true,
		"pnpm": true,
		"cp": true,
		"npx publint": true,
		"read": true,
		"gh": true,
		"true": true,
		"command": true,
		"xdg-settings": true,
		"printf": true,
		"git add": true,
		"git commit": true,
		"git config": true,
		"mv": true,
		"repeat": true,
		"done": true,
		"env": true,
		"/usr/bin/time": true,
		"time": true,
		"/^zsh -fc 'zmodload zsh/datetime; start=\\$EPOCHREALTIME; env -u CONF_LOADED QUIET=1 XDG_BIN_HOME=\\$XDG_BIN_HOME XDG_CONFIG_HOME=\\$XDG_CONFIG_HOME LOADENV_RC_EXTS=\"sh zsh\" zsh -fc '\\\\''\\. \"\\$XDG_BIN_HOME/loadenv\"'\\\\''; end=\\$EPOCHREALTIME; printf \"%\\.6f\\\\n\" \\$\\(\\( end - start \\)\\)'$/": {
			"approve": true,
			"matchCommandLine": true,
		},
		"fnm": true,
		"/opt/homebrew/bin/brew": true,
		"/^node --version && cat /home/alex/git/@webdev/js-tooling/node_modules/\\.pnpm/svelte-preprocess@6\\.0\\.4_postcss-load-config@3\\.1\\.4_postcss@8\\.5\\.15_ts-node@10\\.9\\.2_@types\\+node@2_rqj4cme2v7q3m3iutpckrbsdde/node_modules/svelte-preprocess/package\\.json \\| grep -E '\"version\"\\|\"type\"' \\| head -5$/": {
			"approve": true,
			"matchCommandLine": true,
		},
		"set": true,
		"mkdir": true,
		"update-desktop-database": true,
		"kbuildsycoca6": true,
		"shellcheck": true,
	},
	"chat.agent.maxRequests": 100,
	"lldb-dap.executable-path": "/bin/lldb-dap",
	"window.commandCenter": false,
	"glassit.alpha": 190,
	"glassit.step": 6,
	"github.copilot.nextEditSuggestions.enabled": false,
	"liveServer.settings.donotVerifyTags": true,
	"chat.tools.urls.autoApprove": {
		"https://code.visualstudio.com": true,
		"https://github.com/microsoft/vscode/wiki/*": true,
		"http://localhost:5500": {
			"approveRequest": false,
			"approveResponse": true,
		},
		"https://docs.rs": {
			"approveRequest": false,
			"approveResponse": true,
		},
		"https://crates.io/crates/bevy_egui": true,
		"https://crates.io/crates": true,
		"https://crates.io": true,
		"https://crates.io/crates/bevy-inspector-egui": true,
		"https://bevy.org": {
			"approveRequest": false,
			"approveResponse": true,
		},
		"https://github.com": true,
		"https://raw.githubusercontent.com": {
			"approveRequest": false,
			"approveResponse": true,
		},
		"https://devblogs.microsoft.com": {
			"approveRequest": false,
			"approveResponse": true,
		},
		"https://aka.ms": {
			"approveRequest": false,
			"approveResponse": true,
		},
		"https://huggingface.co": {
			"approveRequest": false,
			"approveResponse": true,
		},
		"https://dioxuslabs.com": {
			"approveRequest": false,
			"approveResponse": true,
		},
	},
	"editor.minimap.enabled": false,
	"diffEditor.ignoreTrimWhitespace": true,
	"chat.plugins.marketplaces": [
		"github/copilot-plugins",
		"github/awesome-copilot",
		"https://github.com/ChromeDevTools/chrome-devtools-mcp",
	],
	"chat.tips.enabled": false,
	"chat.viewSessions.orientation": "stacked",
	"chat.promptFilesLocations": {
		"~/.config/copilot/agents": true,
	},
	"chat.instructionsFilesLocations": {
		"~/.config/copilot/agents": true,
	},
	"chat.modeFilesLocations": {
		"~/.config/copilot/agents": true,
	},
	"chat.agentFilesLocations": {
		"~/.config/copilot/agents": true,
	},
}
